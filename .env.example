# Shared env for frontend + backend

# Frontend (Vite only exposes VITE_* to browser)
VITE_API_BASE=http://127.0.0.1:8000

# Backend
DATABASE_PATH=./data/issue_multi_agent.db
PROJECT_ROOT=.
ENABLE_GITHUB_FETCH=false
GITHUB_TOKEN=

LLM_ENABLED=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
DEBUGGER_REQUIRE_LLM=true
